{
    "dashboard": {
        "id": null,
        "uid": "designika-api",
        "title": "Designika API Monitoring",
        "tags": [
            "designika",
            "api",
            "production"
        ],
        "timezone": "browser",
        "refresh": "30s",
        "panels": [
            {
                "id": 1,
                "title": "API Request Rate",
                "type": "graph",
                "gridPos": {
                    "x": 0,
                    "y": 0,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "sum(rate(http_requests_total{app=\"designika-backend\"}[5m]))",
                        "legendFormat": "Requests/sec"
                    }
                ]
            },
            {
                "id": 2,
                "title": "API Latency (P95)",
                "type": "graph",
                "gridPos": {
                    "x": 12,
                    "y": 0,
                    "w": 12,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"designika-backend\"}[5m])) by (le))",
                        "legendFormat": "P95 Latency"
                    }
                ]
            },
            {
                "id": 3,
                "title": "Error Rate",
                "type": "stat",
                "gridPos": {
                    "x": 0,
                    "y": 8,
                    "w": 6,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "sum(rate(http_requests_total{app=\"designika-backend\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{app=\"designika-backend\"}[5m])) * 100",
                        "legendFormat": "Error %"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "thresholds": {
                            "steps": [
                                {
                                    "value": 0,
                                    "color": "green"
                                },
                                {
                                    "value": 1,
                                    "color": "yellow"
                                },
                                {
                                    "value": 5,
                                    "color": "red"
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 4,
                "title": "Active Workflows",
                "type": "stat",
                "gridPos": {
                    "x": 6,
                    "y": 8,
                    "w": 6,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "temporal_workflow_count{namespace=\"default\", status=\"Running\"}",
                        "legendFormat": "Running"
                    }
                ]
            },
            {
                "id": 5,
                "title": "Database Connections",
                "type": "gauge",
                "gridPos": {
                    "x": 12,
                    "y": 8,
                    "w": 6,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "pg_stat_activity_count{datname=\"designika_db\"}",
                        "legendFormat": "Postgres"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "max": 100,
                        "thresholds": {
                            "steps": [
                                {
                                    "value": 0,
                                    "color": "green"
                                },
                                {
                                    "value": 50,
                                    "color": "yellow"
                                },
                                {
                                    "value": 80,
                                    "color": "red"
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 6,
                "title": "Redis Memory Usage",
                "type": "gauge",
                "gridPos": {
                    "x": 18,
                    "y": 8,
                    "w": 6,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
                        "legendFormat": "Memory %"
                    }
                ]
            },
            {
                "id": 7,
                "title": "Image Generations (24h)",
                "type": "stat",
                "gridPos": {
                    "x": 0,
                    "y": 12,
                    "w": 8,
                    "h": 4
                },
                "targets": [
                    {
                        "expr": "sum(increase(image_generations_total[24h]))",
                        "legendFormat": "Total"
                    }
                ]
            },
            {
                "id": 8,
                "title": "Agent Executions",
                "type": "timeseries",
                "gridPos": {
                    "x": 8,
                    "y": 12,
                    "w": 16,
                    "h": 8
                },
                "targets": [
                    {
                        "expr": "sum(rate(agent_executions_total{app=\"designika-backend\"}[5m])) by (agent)",
                        "legendFormat": "{{agent}}"
                    }
                ]
            }
        ],
        "annotations": {
            "list": [
                {
                    "name": "Deployments",
                    "datasource": "Prometheus",
                    "enable": true,
                    "expr": "changes(deployment_generation{app=\"designika-backend\"}[1m]) > 0"
                }
            ]
        }
    },
    "overwrite": true
}